{
  "name": "id-lens",
  "version": "2.0.0",
  "private": false,
  "type": "module",
  "description": "Universal identifier inspector — paste any ID, see what it is and what's inside.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}' 'tests/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "preact": "10.22.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "2.8.2",
    "@types/node": "20.12.7",
    "@typescript-eslint/eslint-plugin": "7.7.1",
    "@typescript-eslint/parser": "7.7.1",
    "eslint": "8.57.0",
    "jsdom": "24.0.0",
    "playwright": "^1.60.0",
    "prettier": "3.2.5",
    "typescript": "5.4.5",
    "vite": "5.4.21",
    "vitest": "1.6.1"
  }
}
